% cv-style.sty — Shared style for Camilo Ovalle's CV variants
% Paper: legal (8.5" × 14") — fits all content on one page
% Compatible with pdflatex.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv-style}[2026/06/12 Camilo Ovalle CV shared style]

% ── Packages ─────────────────────────────────────────────────────────────────
\RequirePackage[T1]{fontenc}
\RequirePackage[scaled=0.93]{helvet}   % Helvetica ≈ Arial, clean sans-serif
\renewcommand{\familydefault}{\sfdefault}
\RequirePackage{microtype}
\RequirePackage[
  legal,
  top=0.45in, bottom=0.45in,
  left=0.60in, right=0.60in
]{geometry}
\RequirePackage{parskip}
\RequirePackage{xcolor}
\RequirePackage{hyperref}
\RequirePackage{fontawesome5}
\RequirePackage{enumitem}
\RequirePackage{titlesec}

% ── Colors ───────────────────────────────────────────────────────────────────
\definecolor{cvblue}{HTML}{1A56DB}
\definecolor{cvgray}{HTML}{555555}
\definecolor{cvrule}{HTML}{CCCCCC}

% ── Hyperref ─────────────────────────────────────────────────────────────────
\hypersetup{colorlinks=true, urlcolor=cvblue, linkcolor=cvblue, pdfborder={0 0 0}}

% ── Section headings — rule with breathing room below ────────────────────────
\titleformat{\section}{\large\bfseries\scshape}{}{0em}{}[\color{cvrule}\titlerule]
\titlespacing{\section}{0pt}{8pt}{7pt}

% ── List style ───────────────────────────────────────────────────────────────
\setlist[itemize]{leftmargin=1.4em, itemsep=0pt, parsep=0pt, topsep=2pt}

% ── parskip override ─────────────────────────────────────────────────────────
\setlength{\parskip}{0pt}

% ── Commands ─────────────────────────────────────────────────────────────────

% \cvheader{name}{headline}{contact — use \\ to split lines}
\newcommand{\cvheader}[3]{%
  \begin{center}
    {\LARGE\bfseries #1}\\[2pt]
    {\large\color{cvgray} #2}\\[4pt]
    {\small #3}
  \end{center}
  \vspace{1pt}
}

% \cventry{Job Title}{Company}{Date range}
\newcommand{\cventry}[3]{%
  \noindent
  \textbf{#1} \hfill {\color{cvgray}\textit{#3}}\\[-2pt]
  {\color{cvgray}\textit{#2}}
  \vspace{1pt}
}

% \cvproject{Project Name | Tech}{URL}  — no underline
\newcommand{\cvproject}[2]{%
  \noindent
  \textbf{#1}%
  \ifx&#2&\else\quad{\small\color{cvgray}\href{#2}{#2}}\fi
  \vspace{1pt}
}

% \cveducation{Degree}{Institution}{Date range}
\newcommand{\cveducation}[3]{%
  \noindent
  \textbf{#1} \hfill {\color{cvgray}\textit{#3}}\\[-2pt]
  {\color{cvgray}\textit{#2}}
  \vspace{1pt}
}

% \cvskillrow{Category}{Skills}
\newcommand{\cvskillrow}[2]{%
  \noindent\textbf{#1:} #2\\[1pt]
}
